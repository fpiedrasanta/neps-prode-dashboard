# Copiar este archivo como .env y completar con tus valores locales
# Este archivo .env.example SI se sube a GitHub como plantilla de referencia

# Entorno
VITE_NODE_ENV=development
VITE_APP_NAME=Neps Prode Dashboard

# API Configuracion
VITE_API_BASE_URL=http://localhost:3000/api
VITE_API_TIMEOUT=15000

# Autenticacion
VITE_JWT_SECRET_KEY=
VITE_TOKEN_EXPIRE_DAYS=7

# Otros
VITE_ENABLE_DEBUG=true
VITE_LOG_LEVEL=info